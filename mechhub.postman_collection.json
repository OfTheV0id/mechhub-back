{
  "info": {
    "name": "MechHub Backend",
    "description": "用户系统接口集合。\n\n变量:\n- baseUrl:后端地址,默认 http://localhost:8080\n- email / password:测试账号\n- verifyToken / resetToken:邮件里拿到的 token,手动填\n\nCookie 由 Postman 自动管理,登录后调 /user/me、/user/change-password 会自动带上 session_id。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "mechhub-backend-collection"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "email", "value": "test@example.com", "type": "string" },
    { "key": "password", "value": "abcd1234", "type": "string" },
    { "key": "newPassword", "value": "xyz98765", "type": "string" },
    { "key": "verifyToken", "value": "", "type": "string" },
    { "key": "resetToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "提交邮箱密码注册。后端会发一封带 verify token 的邮件,并在 mongo tokens 集合里写一条记录。\n\n返回 200 后,从邮箱(或 mongo)拿 token,填到 collection 变量 verifyToken,然后调 Verify Email。"
          }
        },
        {
          "name": "2. Verify Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify?token={{verifyToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify"],
              "query": [{ "key": "token", "value": "{{verifyToken}}" }]
            },
            "description": "用 verify token 激活账号。token 一次性,用过即失效。"
          }
        },
        {
          "name": "3. Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "成功后响应里会带 Set-Cookie: session_id=xxx,Postman cookie jar 自动保存。后续需要登录的接口会自动带 cookie,无需手动加。"
          }
        },
        {
          "name": "4. Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "删掉服务端 session,清掉 cookie。"
          }
        },
        {
          "name": "5. Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            },
            "description": "发重置邮件(无论邮箱是否存在都返回成功,防枚举)。从邮箱/mongo 拿 reset token 填到 resetToken 变量。"
          }
        },
        {
          "name": "6. Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "用 reset token 设置新密码。成功后该用户所有 session 全部失效。"
          }
        }
      ]
    },
    {
      "name": "User (需要登录)",
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "me"]
            },
            "description": "返回当前登录用户信息。需要先调 Login 拿 cookie。"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"{{password}}\",\n  \"new_password\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "change-password"]
            },
            "description": "已登录用户改密。成功后所有 session 失效,需要重新登录。"
          }
        }
      ]
    }
  ]
}
