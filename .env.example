PORT=8080

MYSQL_DSN=mechhub:mechhub@tcp(localhost:3306)/mechhub?charset=utf8mb4&parseTime=true&loc=UTC

CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,https://mechhub.com

SESSION_COOKIE_NAME=session_id
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

RESEND_API_KEY=
MAIL_FROM=no-reply@mechhub.com
MAIL_LOGO_URL=https://mechhub-avatars.oss-cn-shanghai.aliyuncs.com/static/mail-logo.webp
MAIL_BG_URL=https://mechhub-avatars.oss-cn-shanghai.aliyuncs.com/static/mail-bg.webp
ADMIN_EMAILS=admin@example.com,owner@example.com
APP_BASE_URL=http://localhost:3000


VERIFY_TOKEN_TTL_HOURS=24
RESET_TOKEN_TTL_MINUTES=30
TEACHER_APPROVAL_TTL_HOURS=168

OSS_REGION=cn-shanghai
OSS_BUCKET=mechhub-oss
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=


AVATAR_MAX_BYTES=2097152

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEFAULT_RETURN_URL=http://localhost:5173
# 后端外部 URL,构造 avatar/attachment/Google callback 用。
# 默认 http://localhost:<PORT>,开发无需设置;生产填真实域名。
# BACKEND_BASE_URL=https://mechhub.oftheloneliness.cn

# Root agent 后端选择。可选 "gemini"(默认)或 "openai-compat"。
# grade_with_ocr 工具内部 vision+structured output 恒走 Gemini,与此无关。
LLM_PROVIDER=openai-compat

# Gemini API(直接走 Google AI Studio,无需 Vertex)。轮 7 起 Go 端直接接 ADK Go,
# 不再调 Python agent;mechhub-agent 仓库归档不再 deploy。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 给 grade_with_ocr 工具内部用的批改专用模型,留空时复用 GEMINI_MODEL。
GEMINI_GRADER_MODEL=
# 可选:Gemini API 自定义入口(走中转 / 代理时填,例如 https://your-proxy.example.com/)。
# 留空走官方 https://generativelanguage.googleapis.com/
GEMINI_BASE_URL=

# OpenAI ChatCompletions-兼容后端。LLM_PROVIDER=openai-compat 时必填。
# 任意兼容 OpenAI 的厂商都行(DeepSeek / Qwen / OpenRouter / vLLM / Ollama)。
# 例:DeepSeek V4-Pro
#   OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_COMPAT_API_KEY=sk-...
#   OPENAI_COMPAT_MODEL=deepseek-v4-pro
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=
# 模型是否支持 image_url 多模态:DeepSeek V4 主线 / Qwen 文本版 = false(默认);
# qwen-vl-max / GPT-4o 这类带视觉的 = true。false 时图片不发给 root LLM,
# 由工具(grade_with_ocr / ocr_images_cached)从 session 缓存按 index 取。
OPENAI_COMPAT_VISION=false

# ── 标题专用模型(OpenAI 兼容)──────────────────────────────────
# 仅用于会话首轮自动标题生成,与主聊天模型完全解耦,可指向更快更便宜的小模型。
# 例:DeepSeek V3.2 chat
#   TITLE_MODEL_BASE_URL=https://api.deepseek.com
#   TITLE_MODEL_API_KEY=sk-...
#   TITLE_MODEL_NAME=deepseek-chat
# 三项任一为空 → 回退到 root model 做标题(慢但能跑)。
TITLE_MODEL_BASE_URL=https://api.deepseek.com
TITLE_MODEL_API_KEY=
TITLE_MODEL_NAME=

# 网页搜索(web_search 工具用)。Tavily Search API,免费档每月 1000 次。
# https://app.tavily.com 注册拿 key;留空时 web_search 工具返回 error。
TAVILY_API_KEY=

# Document AI(grade_submission / ocr_images_cached 工具用)
GOOGLE_CLOUD_PROJECT_ID=
DOCUMENTAI_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=
OCR_IMAGELESS_MODE=true
OCR_ENABLE_IMAGE_QUALITY=true
OCR_ENABLE_MATH_OCR=true
# Document AI 鉴权:gcloud ADC JSON 文件,或在容器里挂 service account。
GOOGLE_APPLICATION_CREDENTIALS=

SOLOCHAT_MAX_ATTACHMENTS_PER_MESSAGE=4
SOLOCHAT_MAX_FILE_SIZE_BYTES=20971520

# 学习板块:课程媒体(图/音/视频)单文件大小上限,字节。
COURSE_MAX_FILE_SIZE_BYTES=52428800

# 轮 7:Mongo 已彻底退场,数据全在 MySQL。GORM AutoMigrate 启动期自动建表,
# 旧的 SOLOCHAT_MIGRATE_DROP_GRADING / SOLOCHAT_MIGRATE_DROP_MESSAGES 不再使用。
