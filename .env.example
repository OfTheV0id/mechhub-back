PORT=8080

MONGO_URI=mongodb://localhost:27017
MONGO_DB=mechhub

CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,https://mechhub.com

SESSION_COOKIE_NAME=session_id
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

RESEND_API_KEY=
MAIL_FROM=no-reply@mechhub.com
MAIL_LOGO_URL=https://mechhub-avatars.oss-cn-shanghai.aliyuncs.com/static/mail-logo.webp
MAIL_BG_URL=https://mechhub-avatars.oss-cn-shanghai.aliyuncs.com/static/mail-bg.webp
ADMIN_EMAILS=admin@example.com,owner@example.com
APP_BASE_URL=http://localhost:3000

VERIFY_TOKEN_TTL_HOURS=24
RESET_TOKEN_TTL_MINUTES=30
TEACHER_APPROVAL_TTL_HOURS=168

OSS_REGION=cn-shanghai
OSS_BUCKET=mechhub-avatars
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=https://mechhub-avatars.oss-cn-shanghai.aliyuncs.com

AVATAR_MAX_BYTES=2097152

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
GOOGLE_DEFAULT_RETURN_URL=http://localhost:5173

AGENT_BASE_URL=http://localhost:8001
AGENT_REQUEST_TIMEOUT_SECONDS=600

SOLOCHAT_MAX_ATTACHMENTS_PER_MESSAGE=4
SOLOCHAT_MAX_FILE_SIZE_BYTES=20971520

# 一次性迁移开关:首次部署时设为 true,把旧的批改专属集合
# (solochat_grading_tasks / solochat_grading_task_files /
# solochat_grading_annotations) drop 掉。drop 完后改回 false。
SOLOCHAT_MIGRATE_DROP_GRADING=false
